@model HappyHouse.Models.HopDong

@{
    ViewBag.Title = "Sửa hợp đồng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var dsDichVuToaNha = ViewBag.DsDichVuToaNha
        as List<HappyHouse.Models.GiaDichVu>;
    var dsDichVuHopDong = ViewBag.DsDichVuHopDong
        as List<HappyHouse.Models.HopDong_DichVu>;
    var daDungIds = dsDichVuHopDong != null
        ? dsDichVuHopDong.ToDictionary(
            x => x.MaGiaDichVu, x => x.SoLuong)
        : new System.Collections.Generic.Dictionary<string, int>();
}

@section breadTitle {
    <h2 style="font-weight:bold;color:black">Hợp đồng thuê phòng</h2>
}
@section breadLink {
    <a href="@Url.Action("DanhSach","ChuTroHopDong")">Danh sách hợp đồng</a>
}

@using (Html.BeginForm("SuaThongTin", "ChuTroHopDong", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="MaHopDong" value="@Model.MaHopDong" />

    <div class="card shadow-sm mb-4">
        <div class="card-header font-weight-bold text-primary">
            <i class="fa fa-building mr-2"></i> Phòng
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-0">
                        <label class="font-weight-bold">Phòng</label>
                        <input type="text" class="form-control" readonly
                               value="@(Model.PhongTro != null
                                   ? "Phòng " + Model.PhongTro.SoPhong
                                     + " — " + Model.PhongTro.ToaNha.TenToaNha
                                   : "")" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header font-weight-bold text-primary">
            <i class="fa fa-user mr-2"></i> Khách hàng
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-0">
                        <label class="font-weight-bold">Tìm kiếm khách hàng</label>
                        <div class="input-group">
                            <input type="text" id="inputTimKhach"
                                   class="form-control"
                                   placeholder="Họ tên, SĐT, email..."
                                   value="@(Model.NguoiDung != null
                                       ? Model.NguoiDung.HoTen
                                         + " — " + Model.NguoiDung.SoDienThoai
                                       : "")" />
                            <div class="input-group-append">
                                <span class="input-group-text">
                                    <i class="fa fa-search"></i>
                                </span>
                            </div>
                        </div>
                        <div id="ketQuaTimKhach"
                             class="list-group mt-1 shadow"
                             style="display:none;position:absolute;
                                    z-index:999;width:100%;
                                    max-height:220px;overflow-y:auto;">
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div id="khachDaChon"
                         class="alert alert-light border"
                         style="@(Model.NguoiDung != null
                                    ? "" : "display:none")">
                        <i class="fa fa-user-check mr-2 text-success"></i>
                        <strong id="tenKhachHienThi">
                            @(Model.NguoiDung?.HoTen ?? "")
                        </strong>
                        <br />
                        <small id="infoKhachHienThi" class="text-muted">
                            @(Model.NguoiDung != null
                                ? Model.NguoiDung.SoDienThoai
                                  + " — " + Model.NguoiDung.Email
                                : "")
                        </small>
                    </div>
                </div>
            </div>
            <input type="hidden" name="MaKhachHang" id="hiddenMaKhach"
                   value="@Model.MaKhachHang" />
        </div>
    </div>

    if (dsDichVuToaNha != null && dsDichVuToaNha.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header font-weight-bold text-primary">
                <i class="fa fa-cog mr-2"></i> Dịch vụ kèm theo
            </div>
            <div class="card-body">
                <div class="row" id="dsDichVu">
                    @foreach (var dv in dsDichVuToaNha)
                    {
                        bool daChon = daDungIds.ContainsKey(dv.MaGiaDichVu);
                        int sl = daChon ? daDungIds[dv.MaGiaDichVu] : 1;

                        <div class="col-md-4 mb-3">
                            <div class="card border @(daChon ? "border-warning" : "") h-100">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between
                                                align-items-start">
                                        <div>
                                            <i class="fas @(dv.TienIch?.BieuTuong ?? "fa-cog")
                                                       mr-2 text-warning"></i>
                                            <strong>
                                                @(dv.TienIch?.TenTienIch ?? dv.TenDichVu)
                                            </strong>
                                            <br />
                                            <small class="text-muted">
                                                @String.Format("{0:N0}", dv.DonGia)đ/@dv.DonVi
                                            </small>
                                        </div>
                                        <input type="checkbox"
                                               class="chkDichVu mt-1"
                                               data-ma="@dv.MaGiaDichVu"
                                               data-gia="@dv.DonGia"
                                               @(daChon ? "checked" : "")
                                               style="width:18px;height:18px;
                                                      cursor:pointer;" />
                                    </div>

                                    <div class="mt-2 soLuongWrap"
                                         style="@(daChon ? "" : "display:none")">
                                        <label class="small font-weight-bold mb-1">
                                            Số lượng:
                                        </label>
                                        <div class="input-group input-group-sm">
                                            <div class="input-group-prepend">
                                                <button type="button"
                                                        class="btn btn-outline-secondary btnMinus">
                                                    <i class="fa fa-minus"></i>
                                                </button>
                                            </div>
                                            <input type="number"
                                                   class="form-control text-center inputSoLuong"
                                                   value="@sl" min="1" max="99"
                                                   data-ma="@dv.MaGiaDichVu" />
                                            <div class="input-group-append">
                                                <button type="button"
                                                        class="btn btn-outline-secondary btnPlus">
                                                    <i class="fa fa-plus"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    @if (daChon)
                                    {
                                        <input type="hidden"
                                               name="dsMaGiaDichVu"
                                               id="hidden_ma_@dv.MaGiaDichVu"
                                               value="@dv.MaGiaDichVu" />
                                        <input type="hidden"
                                               name="dsSoLuong"
                                               id="hidden_sl_@dv.MaGiaDichVu"
                                               value="@sl" />
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header font-weight-bold text-primary">
            <i class="fa fa-file-contract mr-2"></i> Thông tin hợp đồng
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Ngày bắt đầu <span class="text-danger">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.NgayBatDau, "{0:yyyy-MM-dd}", new
                        {
                            @class = "form-control",
                            type = "date"
                        })
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Ngày kết thúc <span class="text-danger">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.NgayKetThuc, "{0:yyyy-MM-dd}", new
                        {
                            @class = "form-control",
                            type = "date"
                        })
                        @Html.ValidationMessageFor(m => m.NgayKetThuc, "",
                            new { @class = "text-danger small" })
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Giá thuê (đ/tháng) <span class="text-danger">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.GiaThueThang, new
                        {
                            @class = "form-control",
                            type = "number",
                            min = "0",
                            step = "50000"
                        })
                        @Html.ValidationMessageFor(m => m.GiaThueThang, "",
                            new { @class = "text-danger small" })
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">Tiền cọc (đ)</label>
                        @Html.TextBoxFor(m => m.TienCoc, new
                        {
                            @class = "form-control",
                            type = "number",
                            min = "0",
                            step = "50000"
                        })
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Ngày thanh toán hàng tháng
                        </label>
                        @Html.TextBoxFor(m => m.NgayThanhToanHangThang, new
                        {
                            @class = "form-control",
                            type = "number",
                            min = "1",
                            max = "28"
                        })
                        <small class="text-muted">Ngày 1 đến 28</small>
                    </div>
                </div>
                <div class="col-md-9">
                    <div class="form-group">
                        <label class="font-weight-bold">Điều khoản</label>
                        @Html.TextAreaFor(m => m.DieuKhoan, new
                        {
                            @class = "form-control",
                            rows = 3
                        })
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between">
        @Html.ActionLink("Trở lại", "DanhSach", null,
            new { @class = "btn btn-secondary px-4" })
        <button type="submit" class="btn btn-warning px-4">
            <i class="fa fa-save mr-1"></i> Lưu thay đổi
        </button>
    </div>
}

@section Scripts {
    <script>
var urlKhach = '@Url.Action("TimKiemKhachHang","ChuTroHopDong")';

// ── Tìm kiếm khách hàng ──────────────────────────────────────
var timer;
$('#inputTimKhach').on('input', function () {
    clearTimeout(timer);
    var q = $(this).val().trim();
    if (q.length < 2) { $('#ketQuaTimKhach').hide(); return; }

    timer = setTimeout(function () {
        $.getJSON(urlKhach, { tuKhoa: q }, function (ds) {
            if (!ds.length) {
                $('#ketQuaTimKhach').html(
                    '<div class="list-group-item text-muted small">'
                    + 'Không tìm thấy</div>').show();
                return;
            }
            var html = '';
            ds.forEach(function (k) {
                html += '<a href="#" class="list-group-item'
                      + ' list-group-item-action itemKhach"'
                      + ' data-ma="'    + k.maNguoiDung  + '"'
                      + ' data-ten="'   + k.hoTen        + '"'
                      + ' data-sdt="'   + k.soDienThoai  + '"'
                      + ' data-email="' + k.email        + '">'
                      + '<strong>' + k.hoTen + '</strong>'
                      + ' <span class="text-muted">— '
                      + k.soDienThoai + '</span>'
                      + '<br><small class="text-muted">'
                      + k.email + '</small></a>';
            });
            $('#ketQuaTimKhach').html(html).show();
        });
    }, 300);
});

$(document).on('click', '.itemKhach', function (e) {
    e.preventDefault();
    $('#hiddenMaKhach').val($(this).data('ma'));
    $('#tenKhachHienThi').text($(this).data('ten'));
    $('#infoKhachHienThi').text(
        $(this).data('sdt') + ' — ' + $(this).data('email'));
    $('#khachDaChon').show();
    $('#ketQuaTimKhach').hide();
    $('#inputTimKhach').val('');
});

$(document).on('click', function (e) {
    if (!$(e.target).closest('#inputTimKhach,#ketQuaTimKhach').length)
        $('#ketQuaTimKhach').hide();
});

// ── Dịch vụ checkbox ─────────────────────────────────────────
$(document).on('change', '.chkDichVu', function () {
    var card = $(this).closest('.card-body');
    var ma   = $(this).data('ma');

    if ($(this).is(':checked')) {
        card.find('.soLuongWrap').show();
        $('<input>').attr({ type:'hidden', name:'dsMaGiaDichVu',
            id:'hidden_ma_'+ma, value:ma }).appendTo('form');
        $('<input>').attr({ type:'hidden', name:'dsSoLuong',
            id:'hidden_sl_'+ma, value:1 }).appendTo('form');
    } else {
        card.find('.soLuongWrap').hide();
        $('#hidden_ma_'+ma).remove();
        $('#hidden_sl_'+ma).remove();
    }
});

$(document).on('click', '.btnMinus', function () {
    var inp = $(this).closest('.input-group').find('.inputSoLuong');
    var v = Math.max(1, parseInt(inp.val()) - 1);
    inp.val(v).trigger('change');
});

$(document).on('click', '.btnPlus', function () {
    var inp = $(this).closest('.input-group').find('.inputSoLuong');
    inp.val(parseInt(inp.val()) + 1).trigger('change');
});

$(document).on('change', '.inputSoLuong', function () {
    var ma = $(this).data('ma');
    $('#hidden_sl_'+ma).val($(this).val());
});
    </script>
}