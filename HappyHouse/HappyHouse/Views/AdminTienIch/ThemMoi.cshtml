@model HappyHouse.Models.TienIch

@{
    ViewBag.Title = "Thêm tiện ích";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@section breadTitle {
    <h2 style="font-weight:bold;color:black">Quản lý tiện ích</h2>
}
@section breadLink {
    <a href="@Url.Action("DanhSach","AdminTienIch")">
        Danh sách tiện ích
    </a>
}

@using (Html.BeginForm("ThemMoi", "AdminTienIch",
    FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-md-8">

            <div class="form-group">
                <label class="font-weight-bold">
                    Tên tiện ích
                    <span class="text-danger">*</span>
                </label>
                @Html.TextBoxFor(m => m.TenTienIch, new
                {
                    @class = "form-control",
                    placeholder = "VD: Internet, Giu xe may...",
                    maxlength = "100",
                    id = "inputTen"
                })
                @Html.ValidationMessageFor(m => m.TenTienIch,
                    "", new { @class = "text-danger small" })
            </div>

            <div class="form-group">
                <label class="font-weight-bold">
                    Class icon Font Awesome
                    <span class="text-danger">*</span>
                </label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"
                              style="width:50px;font-size:20px;
                                     justify-content:center;">
                            <i class="fas fa-question"
                               id="previewIcon"></i>
                        </span>
                    </div>
                    @Html.TextBoxFor(m => m.BieuTuong, new
                    {
                        @class = "form-control",
                        placeholder =
                            "VD: fa-wifi, fa-motorcycle, fa-trash...",
                        maxlength = "100",
                        id = "inputIcon",
                        oninput = "capNhatIcon(this.value)"
                    })
                </div>
                @Html.ValidationMessageFor(m => m.BieuTuong,
                    "", new { @class = "text-danger small" })
                <small class="text-muted">
                    Tim icon tai
                    <a href="https://fontawesome.com/icons"
                       target="_blank">
                        fontawesome.com/icons
                    </a>
                    — chi nhap ten class VD:
                    <code>fa-wifi</code>
                </small>
            </div>

            <div class="form-group">
                <label class="font-weight-bold d-block">
                    Loại tiện ích
                </label>
                <div class="d-flex">
                    <div class="custom-control custom-radio mr-4">
                        <input type="radio" id="rdHienThi"
                               name="CoTinhTien"
                               value="false"
                               class="custom-control-input"
                               checked="checked" />
                        <label class="custom-control-label"
                               for="rdHienThi">
                            <i class="fa fa-eye mr-1 text-info"></i>
                            <strong>Hiển thị</strong>
                            <span class="text-muted small d-block">
                                Dieu hoa, Ban cong... (khong thu tien)
                            </span>
                        </label>
                    </div>
                    <div class="custom-control custom-radio">
                        <input type="radio" id="rdTinhTien"
                               name="CoTinhTien"
                               value="true"
                               class="custom-control-input" />
                        <label class="custom-control-label"
                               for="rdTinhTien">
                            <i class="fa fa-dollar-sign mr-1
                               text-warning"></i>
                            <strong>Tính tiền</strong>
                            <span class="text-muted small d-block">
                                Internet, Rac, Xe may... (co gia)
                            </span>
                        </label>
                    </div>
                </div>
            </div>

        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header font-weight-bold
                            text-primary">
                    <i class="fa fa-eye mr-2"></i> Xem trước
                </div>
                <div class="card-body text-center py-4">
                    <div style="font-size:48px;margin-bottom:10px;">
                        <i class="fas fa-question text-primary"
                           id="bigPreviewIcon"></i>
                    </div>
                    <h6 id="previewName"
                        class="font-weight-bold text-muted">
                        Tên tiện ích
                    </h6>
                    <span id="previewBadge"
                          class="badge badge-info
                                 px-3 py-1 mt-1">
                        Hiển thị
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between mt-3">
        @Html.ActionLink("Trở lại", "DanhSach", null,
            new { @class = "btn btn-secondary px-4" })
        <button type="submit" class="btn btn-primary px-4">
            <i class="fa fa-plus mr-1"></i> Thêm tiện ích
        </button>
    </div>
}

@section Scripts {
    <script>
        function capNhatIcon(val) {
            var cls = val.trim() || 'fa-question';
            $('#previewIcon').attr('class', 'fas ' + cls);
            $('#bigPreviewIcon')
                .attr('class', 'fas ' + cls + ' text-primary');
        }

        $('#inputTen').on('input', function () {
            $('#previewName').text($(this).val() || 'Ten tien ich');
        });

        $('[name=CoTinhTien]').on('change', function () {
            var laTinhTien = $(this).val() === 'true';
            if (laTinhTien) {
                $('#previewBadge')
                    .removeClass('badge-info')
                    .addClass('badge-warning')
                    .html('<i class="fa fa-dollar-sign mr-1"></i>'
                        + 'Tinh tien');
            } else {
                $('#previewBadge')
                    .removeClass('badge-warning')
                    .addClass('badge-info')
                    .html('<i class="fa fa-eye mr-1"></i>'
                        + 'Hien thi');
            }
        });
    </script>
}