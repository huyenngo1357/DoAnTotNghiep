@model HappyHouse.Models.ChuDeTinTuc

@{
    ViewBag.Title = "Sửa chủ đề tin tức";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@section breadTitle {
    <h2 style="font-weight:bold;color:black">
        Quản lý chủ đề tin tức
    </h2>
}
@section breadLink {
    <a href="@Url.Action("DanhSach","AdminChuDeTinTuc")">
        Danh sách chủ đề
    </a>
}

<div class="row">
    <div class="col-md-8">
        @using (Html.BeginForm("SuaThongTin", "AdminChuDeTinTuc", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.MaChuDe)

            <div class="card shadow-sm mb-4">
                <div class="card-header font-weight-bold text-primary">
                    <i class="fa fa-edit mr-2"></i>
                    Sửa chủ đề
                </div>

                <div class="card-body">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Tên chủ đề <span class="text-danger">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.TenChuDe, new
                        {
                            @class = "form-control",
                            placeholder = "Nhập tên chủ đề...",
                            maxlength = "100"
                        })
                        @Html.ValidationMessageFor(m => m.TenChuDe, "", new { @class = "text-danger small" })
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Mô tả</label>
                        @Html.TextAreaFor(m => m.MoTa, new
                        {
                            @class = "form-control",
                            rows = 3,
                            placeholder = "Mô tả về chủ đề...",
                            maxlength = "255"
                        })
                    </div>

                    <div class="form-group mb-0">
                        <label class="font-weight-bold">Trạng thái</label>
                        @Html.DropDownListFor(m => m.TrangThai,
                            new SelectList(new[]
                            {
                                new { Value = "true", Text = "Hoạt động" },
                                new { Value = "false", Text = "Đã ẩn" }
                            }, "Value", "Text", Model.TrangThai.ToString().ToLower()),
                            new { @class = "form-control" })
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                @Html.ActionLink("Trở lại", "DanhSach", null,
                    new { @class = "btn btn-secondary px-4" })

                <button type="submit" class="btn btn-warning px-4">
                    <i class="fa fa-save mr-1"></i>
                    Cập nhật
                </button>
            </div>
        }
    </div>

    <div class="col-md-4">

        <!-- Thông tin -->
        <div class="card shadow-sm mb-4">
            <div class="card-header font-weight-bold text-primary">
                <i class="fa fa-info-circle mr-2"></i>
                Thông tin
            </div>

            <div class="card-body">
                <table class="table table-borderless table-sm mb-0">
                    <tr>
                        <td class="font-weight-bold" style="width:100px">Mã:</td>
                        <td><code>@Model.MaChuDe</code></td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold">Ngày tạo:</td>
                        <td>
                            <small>
                                @(Model.NgayTao.HasValue
                                    ? Model.NgayTao.Value.ToString("dd/MM/yyyy HH:mm")
                                    : "—")
                            </small>
                        </td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold">Cập nhật:</td>
                        <td>
                            <small>
                                @(Model.NgayCapNhat.HasValue
                                    ? Model.NgayCapNhat.Value.ToString("dd/MM/yyyy HH:mm")
                                    : "—")
                            </small>
                        </td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold">Số bài:</td>
                        <td>
                            <span class="badge badge-primary">
                                @(Model.TinTucs != null
                                    ? Model.TinTucs.Count(x => x.TrangThai == true)
                                    : 0)
                                bài viết
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold">Trạng thái:</td>
                        <td>
                            @if (Model.TrangThai)
                            {
                                <span class="badge badge-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Đã ẩn</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header font-weight-bold text-primary">
                <i class="fa fa-cogs mr-2"></i>
                Thao tác nhanh
            </div>

            <div class="card-body">
                @using (Html.BeginForm("DoiTrangThai", "AdminChuDeTinTuc", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="maChuDe" value="@Model.MaChuDe" />

                    <button type="submit"
                            class="btn btn-block mb-2 @(Model.TrangThai ? "btn-warning" : "btn-success")"
                            onclick="return confirm('@(Model.TrangThai ? "Ẩn chủ đề này?" : "Hiện chủ đề này?")')">

                        <i class="fa @(Model.TrangThai ? "fa-eye-slash" : "fa-eye") mr-1"></i>
                        @(Model.TrangThai ? "Ẩn chủ đề" : "Hiện chủ đề")
                    </button>
                }

                @Html.ActionLink("← Về danh sách", "DanhSach", null,
                    new { @class = "btn btn-secondary btn-block" })
            </div>
        </div>

    </div>
</div>