@model HappyHouse.Models.NguoiDung

@{
    ViewBag.Title = "Sửa thông tin người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@section breadTitle {
    <h2 style="font-weight:bold; color:black">Quản lý người dùng</h2>
}
@section breadLink {
    <a href="@Url.Action("DanhSach","AdminNguoiDung")">Danh sách người dùng</a>
}

@using (Html.BeginForm("SuaThongTin", "AdminNguoiDung", FormMethod.Post,
    new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="MaNguoiDung" value="@Model.MaNguoiDung" />

    @* ── CARD CHI TIẾT + SỬA: layout 2 cột ── *@
    <div class="row">

        @* Cột trái: Ảnh + thông tin tóm tắt *@
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.AnhDaiDien))
                    {
                        <img id="previewAnh"
                             src="~/Content/images/avatars/@Model.AnhDaiDien"
                             style="width:120px; height:120px; object-fit:cover;
                                    border-radius:50%; border:3px solid #4e73df;
                                    display:block; margin:0 auto 12px;" />
                    }
                    else
                    {
                        <div id="avatarDefault"
                             style="width:120px; height:120px; border-radius:50%;
                                    background:#4e73df; color:#fff; font-size:48px;
                                    font-weight:bold; display:flex;
                                    align-items:center; justify-content:center;
                                    margin:0 auto 12px;">
                            @Model.HoTen.Substring(0, 1).ToUpper()
                        </div>
                        <img id="previewAnh" src="#"
                             style="width:120px; height:120px; object-fit:cover;
                                    border-radius:50%; border:3px solid #4e73df;
                                    display:none; margin:0 auto 12px;" />
                    }

                    <h5 class="font-weight-bold mb-1">@Model.HoTen</h5>
                    <p class="text-muted small mb-2">@Model.Email</p>

                    @{
                        string roleClass = "secondary";
                        string roleName = Model.MaVaiTro;
                        if (Model.VaiTro != null) { roleName = Model.VaiTro.TenVaiTro; }
                        switch (Model.MaVaiTro)
                        {
                            case "CHUTHAU": roleClass = "danger"; break;
                            case "CHUTRO": roleClass = "primary"; break;
                            case "KHACHHANG": roleClass = "info"; break;
                        }
                    }
                    <span class="badge badge-pill badge-@roleClass px-3 py-2 mb-3">
                        @roleName
                    </span>

                    <hr />

                    <div class="text-left small">
                        <p class="mb-1">
                            <i class="fa fa-phone mr-2 text-muted"></i>
                            @(string.IsNullOrEmpty(Model.SoDienThoai) ? "—" : Model.SoDienThoai)
                        </p>
                        <p class="mb-1">
                            <i class="fab fa-telegram mr-2 text-muted"></i>
                            @(string.IsNullOrEmpty(Model.ZaloPhone) ? "—" : Model.ZaloPhone)
                        </p>
                        <p class="mb-1">
                            <i class="fa fa-id-card mr-2 text-muted"></i>
                            @(string.IsNullOrEmpty(Model.SoCCCD) ? "—" : Model.SoCCCD)
                        </p>
                        <p class="mb-1">
                            <i class="fa fa-birthday-cake mr-2 text-muted"></i>
                            @(Model.NgaySinh.HasValue
                                ? Model.NgaySinh.Value.ToString("dd/MM/yyyy") : "—")
                        </p>
                        <p class="mb-1">
                            <i class="fa fa-venus-mars mr-2 text-muted"></i>
                            @(Model.GioiTinh == 1 ? "Nam"
                              : Model.GioiTinh == 0 ? "Nữ"
                              : Model.GioiTinh == 2 ? "Khác" : "—")
                        </p>
                        <p class="mb-1">
                            <i class="fa fa-map-marker-alt mr-2 text-muted"></i>
                            @(string.IsNullOrEmpty(Model.DiaChi) ? "—" : Model.DiaChi)
                        </p>
                        <p class="mb-0">
                            <i class="fa fa-calendar mr-2 text-muted"></i>
                            Ngày tạo:
                            @(Model.NgayTao.HasValue
                                ? Model.NgayTao.Value.ToString("dd/MM/yyyy") : "—")
                        </p>
                    </div>

                    <hr />

                    @* Upload ảnh mới *@
                    <div class="form-group text-left mb-0">
                        <label class="font-weight-bold small">Đổi ảnh đại diện:</label>
                        <input type="file" name="anhDaiDien" id="inputAnh"
                               class="form-control-file" accept="image/*" />
                        <small class="text-muted">JPG, PNG. Tối đa 2MB.</small>
                    </div>
                </div>
            </div>
        </div>

        @* Cột phải: Form sửa *@
        <div class="col-md-8">

            @* Card: Thông tin cơ bản *@
            <div class="card shadow-sm mb-4">
                <div class="card-header font-weight-bold text-primary">
                    <i class="fa fa-edit mr-2"></i> Chỉnh sửa thông tin
                </div>
                <div class="card-body">

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">
                                    Họ và tên <span class="text-danger">(*)</span>
                                </label>
                                @Html.TextBoxFor(m => m.HoTen, new
                                {
                                    @class = "form-control",
                                    placeholder = "Nhập họ tên...",
                                    maxlength = "100"
                                })
                                @Html.ValidationMessageFor(m => m.HoTen, "",
                                    new { @class = "err-msg" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">
                                    Vai trò <span class="text-danger">(*)</span>
                                </label>
                                @Html.DropDownList("MaVaiTro",
                                    (SelectList)ViewBag.DsVaiTro,
                                    "--- Chọn vai trò ---",
                                    new { @class = "form-control" })
                                @Html.ValidationMessageFor(m => m.MaVaiTro, "",
                                    new { @class = "err-msg" })
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">
                                    Email <span class="text-danger">(*)</span>
                                </label>
                                @Html.TextBoxFor(m => m.Email, new
                                {
                                    @class = "form-control",
                                    placeholder = "example@email.com",
                                    maxlength = "100",
                                    type = "email"
                                })
                                @Html.ValidationMessageFor(m => m.Email, "",
                                    new { @class = "err-msg" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">
                                    Số điện thoại <span class="text-danger">(*)</span>
                                </label>
                                @Html.TextBoxFor(m => m.SoDienThoai, new
                                {
                                    @class = "form-control",
                                    placeholder = "0xxxxxxxxx",
                                    maxlength = "15"
                                })
                                @Html.ValidationMessageFor(m => m.SoDienThoai, "",
                                    new { @class = "err-msg" })
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">Zalo</label>
                                @Html.TextBoxFor(m => m.ZaloPhone, new
                                {
                                    @class = "form-control",
                                    placeholder = "Số Zalo...",
                                    maxlength = "15"
                                })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">Số CCCD</label>
                                @Html.TextBoxFor(m => m.SoCCCD, new
                                {
                                    @class = "form-control",
                                    placeholder = "Số căn cước công dân...",
                                    maxlength = "20"
                                })
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="font-weight-bold">Ngày sinh</label>
                                @Html.TextBoxFor(m => m.NgaySinh,
                                    Model.NgaySinh.HasValue
                                        ? Model.NgaySinh.Value.ToString("yyyy-MM-dd") : "", new { @class = "form-control", type = "date" })
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="font-weight-bold">Giới tính</label>
                                <select name="GioiTinh" class="form-control">
                                    <option value="">--- Chọn ---</option>
                                    <option value="1" @(Model.GioiTinh == 1 ? "selected" : "")>Nam</option>
                                    <option value="0" @(Model.GioiTinh == 0 ? "selected" : "")>Nữ</option>
                                    <option value="2" @(Model.GioiTinh == 2 ? "selected" : "")>Khác</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="font-weight-bold">Trạng thái</label>
                                <select name="TrangThai" class="form-control">
                                    <option value="true"
                                            @(Model.TrangThai == true ? "selected" : "")>
                                        Hoạt động
                                    </option>
                                    <option value="false"
                                            @(Model.TrangThai == false ? "selected" : "")>
                                        Đã khóa
                                    </option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Địa chỉ</label>
                        @Html.TextBoxFor(m => m.DiaChi, new
                        {
                            @class = "form-control",
                            placeholder = "Địa chỉ...",
                            maxlength = "255"
                        })
                    </div>

                </div>
            </div>

            @* Card: Đổi mật khẩu *@
            <div class="card shadow-sm mb-4">
                <div class="card-header font-weight-bold text-warning">
                    <i class="fa fa-lock mr-2"></i> Đổi mật khẩu
                    <small class="text-muted font-weight-normal ml-2">
                        (để trống nếu không muốn đổi)
                    </small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">Mật khẩu mới</label>
                                <input type="password" name="matKhauMoi"
                                       id="matKhauMoi" class="form-control"
                                       placeholder="Tối thiểu 6 ký tự" />
                                <span id="errMatKhau" class="err-msg"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="font-weight-bold">Xác nhận mật khẩu</label>
                                <input type="password" id="xacNhanMatKhau"
                                       class="form-control"
                                       placeholder="Nhập lại mật khẩu mới" />
                                <span id="errXacNhan" class="err-msg"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                @Html.ActionLink("Trở lại", "DanhSach", null,
                    new { @class = "btn btn-secondary px-4" })
                <button type="submit" id="btnSubmit" class="btn btn-warning px-4">
                    Cập nhật
                </button>
            </div>

        </div>
    </div>
}

<style>
    .err-msg {
        display: none;
        font-size: 12px;
        font-weight: 500;
        margin-top: 5px;
        padding: 4px 10px;
        background: #fff0f0;
        border-left: 3px solid #e74a3b;
        border-radius: 3px;
        color: #e74a3b;
    }

    .field-validation-error.err-msg {
        display: block;
    }

    .field-validation-valid.err-msg {
        display: none !important;
    }

    .input-validation-error {
        border-color: #e74a3b !important;
        background-color: #fff5f5 !important;
    }
</style>

@section Scripts {
    <script>
        // Preview ảnh đại diện mới
        document.getElementById('inputAnh').addEventListener('change', function () {
            var file = this.files[0];
            if (!file || !file.type.startsWith('image/')) return;
            var reader = new FileReader();
            reader.onload = function (e) {
                var preview = document.getElementById('previewAnh');
                var def = document.getElementById('avatarDefault');
                preview.src = e.target.result;
                preview.style.display = 'block';
                if (def) def.style.display = 'none';
            };
            reader.readAsDataURL(file);
        });

        // Kiểm tra mật khẩu khớp
        document.getElementById('xacNhanMatKhau').addEventListener('input', kiemTraMK);
        document.getElementById('matKhauMoi').addEventListener('input', kiemTraMK);

        function kiemTraMK() {
            var mk = document.getElementById('matKhauMoi').value;
            var xn = document.getElementById('xacNhanMatKhau').value;
            var err = document.getElementById('errXacNhan');
            var btn = document.getElementById('btnSubmit');
            if (mk && xn && mk !== xn) {
                err.style.display = 'block';
                err.textContent = 'Mật khẩu không khớp!';
                btn.disabled = true;
            } else {
                err.style.display = 'none';
                btn.disabled = false;
            }
        }

        setTimeout(function () {
            $('.alert').fadeOut('slow', function () { $(this).remove(); });
        }, 1500);
    </script>
}