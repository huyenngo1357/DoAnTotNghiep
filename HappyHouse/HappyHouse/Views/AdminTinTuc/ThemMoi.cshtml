@model HappyHouse.Models.TinTuc

@{
    ViewBag.Title = "Thêm tin tức";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@section breadTitle {
    <h2 style="font-weight:bold; color:black">Quản lý tin tức</h2>
}
@section breadLink {
    <a href="@Url.Action("DanhSach","AdminTinTuc")">Danh sách tin tức</a>
}

@using (Html.BeginForm("ThemMoi", "AdminTinTuc", FormMethod.Post,
    new { enctype = "multipart/form-data", @id = "frmThemTin" }))
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm mb-4">
        <div class="card-header font-weight-bold text-primary">
            <i class="fa fa-newspaper mr-2"></i> Thông tin bài viết
        </div>
        <div class="card-body">

            <div class="row">
                <div class="col-md-8">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Tiêu đề <span class="text-danger">(*)</span>
                        </label>
                        @Html.TextBoxFor(m => m.TieuDe, new
                        {
                            @class = "form-control",
                            placeholder = "Nhập tiêu đề bài viết...",
                            maxlength = "200"
                        })
                        @Html.ValidationMessageFor(m => m.TieuDe, "",
                            new { @class = "err-msg" })
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Chủ đề <span class="text-danger">(*)</span>
                        </label>
                        @Html.DropDownList("MaChuDe",
                            (SelectList)ViewBag.DsChuDe,
                            "--- Chọn chủ đề ---",
                            new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.MaChuDe, "",
                            new { @class = "err-msg" })
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="font-weight-bold">
                    Tóm tắt
                    <span class="text-muted font-weight-normal">
                        (hiển thị ở trang danh sách)
                    </span>
                </label>
                @Html.TextAreaFor(m => m.TomTat, new
                {
                    @class = "form-control",
                    rows = 3,
                    placeholder = "Tóm tắt nội dung bài viết...",
                    maxlength = "500",
                    id = "txtTomTat"
                })
                <small class="text-muted">
                    (<span id="demKyTu">0</span>/500 ký tự)
                </small>
            </div>

            <div class="form-group">
                <label class="font-weight-bold">
                    Nội dung <span class="text-danger">(*)</span>
                </label>

                <!-- Toolbar -->
                <div class="mb-2">
                    <div class="btn-group mr-2" role="group" aria-label="Text style">
                        <button type="button" class="btn btn-light btn-sm" title="In đậm"
                                onclick="execCmd('bold')">
                            <i class="fa fa-bold"></i>
                        </button>
                        <button type="button" class="btn btn-light btn-sm" title="In nghiêng"
                                onclick="execCmd('italic')">
                            <i class="fa fa-italic"></i>
                        </button>
                        <button type="button" class="btn btn-light btn-sm" title="Gạch chân"
                                onclick="execCmd('underline')">
                            <i class="fa fa-underline"></i>
                        </button>
                    </div>

                    <div class="btn-group mr-2" role="group" aria-label="Font size">
                        <select id="fontSizeSel" class="form-control form-control-sm"
                                style="width:auto;display:inline-block"
                                onchange="applyFontSize(this.value)">
                            <option value="">Kích thước</option>
                            <option value="12">12px</option>
                            <option value="14">14px</option>
                            <option value="16">16px</option>
                            <option value="18">18px</option>
                            <option value="20">20px</option>
                            <option value="24">24px</option>
                            <option value="30">30px</option>
                            <option value="36">36px</option>
                        </select>
                    </div>

                    <div class="btn-group" role="group" aria-label="Clear">
                        <button type="button" class="btn btn-light btn-sm" title="Xóa định dạng"
                                onclick="execCmd('removeFormat')">
                            <i class="fa fa-eraser"></i> Xóa định dạng
                        </button>
                    </div>
                </div>

                <!-- Rich editor (contenteditable) -->
                <div id="editor"
                     class="form-control"
                     contenteditable="true"
                     style="min-height:300px; overflow:auto;"
                     placeholder="Nhập nội dung bài viết...">
                    @Html.Raw(Model?.NoiDung ?? "")
                </div>

                <!-- Hidden textarea will receive HTML on submit -->
                @Html.TextAreaFor(m => m.NoiDung, new { @class = "d-none", id = "txtNoiDung" })

                @Html.ValidationMessageFor(m => m.NoiDung, "",
                    new { @class = "err-msg" })
            </div>

        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header font-weight-bold text-primary">
            <i class="fa fa-image mr-2"></i> Ảnh đại diện
        </div>
        <div class="card-body">
            <div class="d-flex align-items-center">
                <div id="previewWrapper" style="margin-right:20px; display:none;">
                    <img id="previewAnh"
                         style="width:160px; height:120px; object-fit:cover;
                                border-radius:6px; border:2px solid #4e73df;" />
                </div>
                <div>
                    <input type="file" name="anhDaiDien" id="inputAnh"
                           class="form-control-file" accept="image/*" />
                    <small class="text-muted d-block mt-1">
                        Định dạng JPG, PNG. Kích thước khuyến nghị 800×450px.
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between">
        @Html.ActionLink("Trở lại", "DanhSach", null,
            new { @class = "btn btn-secondary px-4" })
        <button type="submit" class="btn btn-primary px-4">
            <i class="fa fa-plus mr-2"></i>Thêm tin tức
        </button>
    </div>
}

<style>
    .err-msg {
        display: none;
        font-size: 12px;
        font-weight: 500;
        margin-top: 5px;
        padding: 4px 10px;
        background: #fff0f0;
        border-left: 3px solid #e74a3b;
        border-radius: 3px;
        color: #e74a3b;
    }

    .field-validation-error.err-msg {
        display: block;
    }

    .field-validation-valid.err-msg {
        display: none !important;
    }

    .input-validation-error {
        border-color: #e74a3b !important;
        background-color: #fff5f5 !important;
    }

    /* Ensure the editor looks like a textarea */
    #editor:empty:before {
        content: attr(placeholder);
        color: #6c757d;
    }
</style>

@section Scripts {
    <script>
    // Đếm ký tự tóm tắt
    $('#txtTomTat').on('input', function () {
        $('#demKyTu').text($(this).val().length);
    });

    // Preview ảnh đại diện
    document.getElementById('inputAnh').addEventListener('change', function () {
        var file = this.files[0];
        if (!file || !file.type.startsWith('image/')) return;
        var reader = new FileReader();
        reader.onload = function (e) {
            document.getElementById('previewAnh').src = e.target.result;
            document.getElementById('previewWrapper').style.display = 'block';
        };
        reader.readAsDataURL(file);
    });

    // Simple rich text helpers
    function execCmd(command) {
        document.getElementById('editor').focus();
        // 'removeFormat' is not supported by execCommand in some browsers; handle gracefully.
        if (command === 'removeFormat') {
            document.execCommand('removeFormat', false, null);
            return;
        }
        document.execCommand(command, false, null);
    }

    function applyFontSize(size) {
        if (!size) return;
        var editor = document.getElementById('editor');
        editor.focus();
        var sel = window.getSelection();
        if (!sel || sel.rangeCount === 0) return;

        var range = sel.getRangeAt(0);
        var selectedHtml = range.toString();
        if (!selectedHtml) return;

        // Insert span with style using execCommand insertHTML for compatibility
        var span = '<span style="font-size:' + size + 'px;">' + escapeHtml(selectedHtml) + '</span>';
        document.execCommand('insertHTML', false, span);
    }

    function escapeHtml(text) {
        return text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    // On submit, copy editor HTML into hidden textarea bound to model
    $('#frmThemTin').on('submit', function () {
        var html = document.getElementById('editor').innerHTML;
        // Optional: trim leading/trailing whitespace nodes
        html = html.trim();
        $('#txtNoiDung').val(html);
    });
    </script>
}