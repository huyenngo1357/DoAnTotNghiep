@using HappyHouse.Models
@model HappyHouse.Models.HoaDon

@{
    ViewBag.Title = "Chi Tiết Hóa Đơn";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    ViewBag.ActiveMenu = "TaiKhoan";

    var user = Session["UserOnline"] as NguoiDung;
    var phong = Model.HopDong?.PhongTro;
    var toaNha = phong?.ToaNha;
    var chuTro = toaNha?.NguoiDung;

    var thanhToanMoi = Model.ThanhToans
                           .OrderByDescending(x => x.NgayTao)
                           .FirstOrDefault();

    string badgeColor, trangThaiText;
    switch (Model.TrangThaiHoaDon)
    {
        case "ChuaThanhToan":
            badgeColor = "#dc3545"; trangThaiText = "Chưa Thanh Toán"; break;
        case "ChoDuyet":
            badgeColor = "#ffc107"; trangThaiText = "Chờ Duyệt"; break;
        case "DaThanhToan":
            badgeColor = "#28a745"; trangThaiText = "Đã Thanh Toán"; break;
        case "QuaHan":
            badgeColor = "#dc3545"; trangThaiText = "Quá Hạn"; break;
        default:
            badgeColor = "#6c757d";
            trangThaiText = Model.TrangThaiHoaDon ?? "—"; break;
    }
}

<style>
    .ct2-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 15px rgba(0,0,0,.07);
        padding: 25px;
        margin-bottom: 20px;
    }

    .ct2-title {
        font-weight: 700;
        color: #222;
        margin-bottom: 18px;
        padding-bottom: 10px;
        border-bottom: 2px solid #2cbdb8;
        font-size: 15px;
    }

    .hd-sidebar-menu a {
        display: block;
        padding: 13px 20px;
        font-size: 14px;
        color: #555;
        text-decoration: none;
        border-bottom: 1px solid #f5f5f5;
    }

        .hd-sidebar-menu a.active {
            color: #2cbdb8;
            font-weight: 700;
            border-left: 3px solid #2cbdb8;
            background: #f0fafa;
        }
</style>

<section class="spad" style="background:#f7f8fa;">
    <div class="container">

        <div style="font-size:13px;color:#888;margin-bottom:20px;">
            <a href="@Url.Action("Index","TrangChu")"
               style="color:#2cbdb8;">Trang chủ</a>
            <i class="fa fa-angle-right mx-2"></i>
            <a href="@Url.Action("DanhSach","HoaDon")"
               style="color:#2cbdb8;">Hóa đơn</a>
            <i class="fa fa-angle-right mx-2"></i>
            <span style="color:#555;">@Model.MaHoaDon</span>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="close"
                        data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="close"
                        data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        }

        <div class="row">

            @* ── Sidebar ── *@
            <div class="col-lg-3">
                <div style="background:#fff;border-radius:10px;
                            box-shadow:0 2px 15px rgba(0,0,0,.07);
                            overflow:hidden;margin-bottom:20px;">
                    @if (user != null)
                    {
                        <div style="padding:20px;text-align:center;
                                    background:#f0fafa;
                                    border-bottom:1px solid #c8eeed;">
                            @if (!string.IsNullOrEmpty(user.AnhDaiDien))
                            {
                                <img src="~/Content/images/avatars/@user.AnhDaiDien"
                                     style="width:60px;height:60px;border-radius:50%;
                                            object-fit:cover;
                                            border:2px solid #2cbdb8;
                                            margin-bottom:10px;" />
                            }
                            else
                            {
                                <div style="width:60px;height:60px;border-radius:50%;
                                            background:#2cbdb8;color:#fff;font-size:24px;
                                            font-weight:700;line-height:60px;
                                            margin:0 auto 10px;">
                                    @user.HoTen.Substring(0, 1).ToUpper()
                                </div>
                            }
                            <h6 style="font-weight:700;margin:0;">@user.HoTen</h6>
                            <small style="color:#999;">@user.Email</small>
                        </div>
                    }
                    <div class="hd-sidebar-menu">
                        <a href="@Url.Action("ThongTin","TaiKhoan")">
                            <i class="fa fa-user mr-2"></i>Thông Tin Cá Nhân
                        </a>
                        <a href="@Url.Action("DanhSach","HopDong")">
                            <i class="fa fa-file-text-o mr-2"></i>Hợp Đồng
                        </a>
                        <a href="@Url.Action("DanhSach","HoaDon")"
                           class="active">
                            <i class="fa fa-money mr-2"></i>Hóa Đơn
                        </a>
                        <a href="@Url.Action("DanhSach","DanhGia")">
                            <i class="fa fa-star mr-2"></i>Đánh Giá
                        </a>
                        <a href="@Url.Action("DangXuat","TaiKhoan")"
                           style="color:#e74a3b;">
                            <i class="fa fa-sign-out mr-2"></i>Đăng Xuất
                        </a>
                    </div>
                </div>

                <div class="ct2-card">
                    <div class="ct2-title">
                        <i class="fa fa-info-circle mr-1"
                           style="color:#2cbdb8;"></i>Tóm Tắt
                    </div>
                    <div style="font-size:13px;">
                        @foreach (var r in new[]
                        {
                            new { L="Tháng",
                                  V=Model.ThangHoaDon.ToString("MM/yyyy") },
                            new { L="Hạn TT",
                                  V=Model.HanThanhToan.ToString("dd/MM/yyyy") },
                        })
                        {
                            <div style="display:flex;justify-content:space-between;
                                        padding:7px 0;border-bottom:1px solid #f5f5f5;">
                                <span style="color:#888;">@r.L</span>
                                <span style="font-weight:600;color:#333;">@r.V</span>
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;
                                    padding:10px 0;border-bottom:1px solid #f5f5f5;">
                            <span style="color:#888;">Trạng thái</span>
                            <span style="background:@badgeColor;color:#fff;
                                         padding:2px 8px;border-radius:20px;
                                         font-size:11px;font-weight:700;">
                                @trangThaiText
                            </span>
                        </div>
                        <div style="display:flex;justify-content:space-between;
                                    padding:10px 0;margin-top:4px;">
                            <span style="font-weight:700;color:#222;">Tổng tiền</span>
                            <span style="font-weight:800;color:#2cbdb8;font-size:16px;">
                                @String.Format("{0:N0}", Model.TongTien)đ
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Nội dung chính ── *@
            <div class="col-lg-9">

                @* Header *@
                <div class="ct2-card"
                     style="display:flex;justify-content:space-between;
                            align-items:center;flex-wrap:wrap;gap:10px;
                            padding:20px 24px;">
                    <div>
                        <h5 style="font-weight:800;margin:0 0 4px;">
                            Hóa Đơn
                            <span style="color:#2cbdb8;">
                                #@Model.MaHoaDon
                            </span>
                        </h5>
                        <p style="color:#888;font-size:13px;margin:0;">
                            <i class="fa fa-calendar mr-1"
                               style="color:#2cbdb8;"></i>
                            Tháng @Model.ThangHoaDon.ToString("MM/yyyy")
                            @if (phong != null)
                            {
                                <span>· Phòng @phong.SoPhong</span>
                            }
                            @if (toaNha != null)
                            {
                                <span>· @toaNha.TenToaNha</span>
                            }
                        </p>
                    </div>
                    <span style="background:@badgeColor;color:#fff;
                                 padding:7px 20px;border-radius:20px;
                                 font-size:13px;font-weight:700;">
                        @trangThaiText
                    </span>
                </div>

                @* Chi tiết khoản thu *@
                <div class="ct2-card">
                    <div class="ct2-title">
                        <i class="fa fa-list mr-2"
                           style="color:#2cbdb8;"></i>Chi Tiết Khoản Thu
                    </div>
                    <table style="width:100%;font-size:14px;
                                  border-collapse:collapse;">
                        <thead>
                            <tr style="background:#f8fffe;">
                                <th style="padding:10px 12px;text-align:left;
                                           font-weight:600;color:#555;
                                           border-bottom:2px solid #eee;">
                                    Khoản Thu
                                </th>
                                <th style="padding:10px 12px;text-align:right;
                                           font-weight:600;color:#555;
                                           border-bottom:2px solid #eee;">
                                    Số Tiền
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr style="border-bottom:1px solid #f5f5f5;">
                                <td style="padding:12px;">
                                    <i class="fa fa-home mr-2"
                                       style="color:#2cbdb8;"></i>
                                    Tiền thuê phòng
                                    @if (phong != null)
                                    {
                                        <span style="color:#aaa;font-size:12px;">
                                            (Phòng @phong.SoPhong)
                                        </span>
                                    }
                                </td>
                                <td style="padding:12px;text-align:right;
                                           font-weight:600;">
                                    @String.Format("{0:N0}", Model.TienPhong)đ
                                </td>
                            </tr>

                            @if (Model.TienDien > 0)
                            {
                                <tr style="border-bottom:1px solid #f5f5f5;">
                                    <td style="padding:12px;">
                                        <i class="fa fa-bolt mr-2"
                                           style="color:#2cbdb8;"></i>
                                        Tiền điện
                                        @if (Model.ChiSoDienNuoc != null)
                                        {
                                            <span style="color:#aaa;font-size:12px;">
                                                (@Model.ChiSoDienNuoc.ChiSoDau
                                                → @Model.ChiSoDienNuoc.ChiSoCuoi
                                                = @(Model.ChiSoDienNuoc.ChiSoCuoi
                                                    - Model.ChiSoDienNuoc.ChiSoDau)
                                                kWh)
                                            </span>
                                        }
                                    </td>
                                    <td style="padding:12px;text-align:right;
                                               font-weight:600;">
                                        @String.Format("{0:N0}", Model.TienDien)đ
                                    </td>
                                </tr>
                            }

                            @if (Model.TienNuoc > 0)
                            {
                                <tr style="border-bottom:1px solid #f5f5f5;">
                                    <td style="padding:12px;">
                                        <i class="fa fa-tint mr-2"
                                           style="color:#2cbdb8;"></i>
                                        Tiền nước
                                        @if (Model.ChiSoDienNuoc1 != null)
                                        {
                                            <span style="color:#aaa;font-size:12px;">
                                                (@Model.ChiSoDienNuoc1.ChiSoDau
                                                → @Model.ChiSoDienNuoc1.ChiSoCuoi
                                                = @(Model.ChiSoDienNuoc1.ChiSoCuoi
                                                    - Model.ChiSoDienNuoc1.ChiSoDau)
                                                m³)
                                            </span>
                                        }
                                    </td>
                                    <td style="padding:12px;text-align:right;
                                               font-weight:600;">
                                        @String.Format("{0:N0}", Model.TienNuoc)đ
                                    </td>
                                </tr>
                            }

                            @if (Model.TienDichVu > 0)
                            {
                                <tr style="border-bottom:1px solid #f5f5f5;">
                                    <td style="padding:12px;">
                                        <i class="fa fa-cog mr-2"
                                           style="color:#2cbdb8;"></i>
                                        Phí dịch vụ
                                    </td>
                                    <td style="padding:12px;text-align:right;
                                               font-weight:600;">
                                        @String.Format("{0:N0}", Model.TienDichVu)đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background:#f0fafa;">
                                <td style="padding:14px 12px;font-weight:700;
                                           font-size:16px;color:#333;">
                                    Tổng Cộng
                                </td>
                                <td style="padding:14px 12px;text-align:right;
                                           font-weight:800;font-size:20px;
                                           color:#2cbdb8;">
                                    @String.Format("{0:N0}", Model.TongTien)đ
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                    <div class="row" style="margin-top:18px;">
                        <div class="col-md-6">
                            <p style="color:#777;font-size:13px;margin-bottom:5px;">
                                <i class="fa fa-calendar mr-1"
                                   style="color:#2cbdb8;"></i>
                                <strong>Hạn thanh toán:</strong>
                                @Model.HanThanhToan.ToString("dd/MM/yyyy")
                            </p>
                            @if (Model.NgayThanhToan.HasValue)
                            {
                                <p style="color:#777;font-size:13px;margin:0;">
                                    <i class="fa fa-check-circle mr-1"
                                       style="color:#28a745;"></i>
                                    <strong>Ngày thanh toán:</strong>
                                    @Model.NgayThanhToan.Value
                                    .ToString("dd/MM/yyyy")
                                </p>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Model.GhiChu))
                        {
                            <div class="col-md-6">
                                <div style="padding:10px 14px;background:#f8fffe;
                                            border-radius:6px;
                                            border-left:3px solid #2cbdb8;">
                                    <p style="margin:0;color:#555;font-size:13px;">
                                        <strong>Ghi chú:</strong>
                                        @Model.GhiChu
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @* Upload biên lai *@
                @if (Model.TrangThaiHoaDon == "ChuaThanhToan"
                  || Model.TrangThaiHoaDon == "QuaHan"
                  || Model.TrangThaiHoaDon == "ChoDuyet")
                {
                    <div class="ct2-card">
                        <div class="ct2-title">
                            <i class="fa fa-upload mr-2"
                               style="color:#2cbdb8;"></i>
                            Thanh Toán & Upload Biên Lai
                        </div>

                        @* Thông tin CK *@
                        @if (chuTro != null)
                        {
                            <div style="background:#f8fffe;padding:15px;
                                        border-radius:8px;margin-bottom:20px;
                                        border:1px solid #c8eeed;">
                                <p style="font-weight:700;margin-bottom:10px;
                                          color:#2cbdb8;font-size:14px;">
                                    <i class="fa fa-bank mr-2"></i>
                                    Thông Tin Chuyển Khoản
                                </p>
                                @foreach (var r in new[]
                                {
                                    new { L="Tên chủ trọ", V=chuTro.HoTen },
                                    new { L="SĐT / Zalo",
                                          V=chuTro.SoDienThoai ?? "—" },
                                })
                                {
                                    <p style="color:#555;font-size:13px;
                                              margin-bottom:5px;">
                                        <strong>@r.L:</strong> @r.V
                                    </p>
                                }
                                <p style="margin:0;font-size:13px;color:#555;">
                                    <strong>Số tiền:</strong>
                                    <span style="color:#2cbdb8;font-weight:800;
                                                 font-size:18px;margin-left:6px;">
                                        @String.Format("{0:N0}", Model.TongTien)đ
                                    </span>
                                </p>
                            </div>
                        }

                        @* Biên lai đã upload *@
                        @if (thanhToanMoi != null
                          && !string.IsNullOrEmpty(thanhToanMoi.AnhBienLai))
                        {
                            <div style="margin-bottom:18px;">
                                <p style="font-weight:700;font-size:13px;
                                          color:#555;margin-bottom:8px;">
                                    Biên lai đã tải lên:
                                </p>
                                @{
                                    string extBL = System.IO.Path
                                        .GetExtension(thanhToanMoi.AnhBienLai)
                                        .ToLower();
                                }
                                @if (extBL == ".pdf")
                                {
                                    <a href="~/Content/images/bienlai/@thanhToanMoi.AnhBienLai"
                                       target="_blank"
                                       style="color:#2cbdb8;font-weight:600;">
                                        <i class="fa fa-file-pdf-o mr-1"></i>
                                        Xem biên lai PDF
                                    </a>
                                }
                                else
                                {
                                    <img src="~/Content/images/bienlai/@thanhToanMoi.AnhBienLai"
                                         style="max-width:300px;border-radius:8px;
                                                border:2px solid #c8eeed;" />
                                }
                            </div>
                        }

                        @* Form upload *@
                        @if (Model.TrangThaiHoaDon != "ChoDuyet")
                        {
                            <form action="@Url.Action("UploadBienLai","HoaDon")"
                                  method="post" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="maHoaDon"
                                       value="@Model.MaHoaDon" />

                                <div style="border:2px dashed #2cbdb8;
                                            border-radius:8px;padding:30px;
                                            text-align:center;cursor:pointer;
                                            background:#f8fffe;transition:.2s;"
                                     onclick="document.getElementById(
                                                 'inputBienLai').click()"
                                     onmouseover="this.style.background='#e8f7f6'"
                                     onmouseout="this.style.background='#f8fffe'">
                                    <i class="fa fa-cloud-upload"
                                       style="font-size:36px;color:#2cbdb8;
                                              display:block;margin-bottom:10px;"></i>
                                    <p style="color:#555;margin:0 0 4px;
                                              font-weight:600;">
                                        Nhấn để chọn file biên lai
                                    </p>
                                    <p style="color:#aaa;font-size:12px;margin:0;">
                                        JPG, PNG hoặc PDF (tối đa 5MB)
                                    </p>
                                    <input type="file" id="inputBienLai"
                                           name="bienLai"
                                           accept=".jpg,.jpeg,.png,.pdf"
                                           style="display:none;"
                                           onchange="hienThiTenFile(this)" />
                                </div>

                                <p id="tenFileDaChon"
                                   style="color:#2cbdb8;font-size:13px;
                                          margin-top:8px;display:none;
                                          font-weight:600;"></p>

                                <div style="margin-top:16px;text-align:right;">
                                    <button type="submit"
                                            style="padding:12px 30px;
                                                   background:#2cbdb8;color:#fff;
                                                   border:none;border-radius:8px;
                                                   font-weight:700;cursor:pointer;
                                                   font-size:14px;
                                                   transition:background .2s;"
                                            onmouseover="this.style.background='#24a09b'"
                                            onmouseout="this.style.background='#2cbdb8'">
                                        <i class="fa fa-upload mr-2"></i>
                                        Tải Lên Biên Lai
                                    </button>
                                </div>
                            </form>
                        }
                        else
                        {
                            <div style="background:#fff3cd;padding:18px;
                                        border-radius:8px;text-align:center;">
                                <i class="fa fa-clock-o"
                                   style="color:#856404;font-size:28px;
                                          display:block;margin-bottom:8px;"></i>
                                <p style="color:#856404;margin:0;font-weight:700;">
                                    Biên lai đang chờ xác nhận từ chủ trọ.
                                </p>
                                <p style="color:#856404;font-size:12px;
                                          margin:5px 0 0;">
                                    Vui lòng chờ trong vài giờ.
                                </p>
                            </div>
                        }
                    </div>
                }

                @* Đã thanh toán *@
                @if (Model.TrangThaiHoaDon == "DaThanhToan")
                {
                    <div style="background:#d4edda;border-radius:10px;
                                padding:24px;margin-bottom:20px;
                                text-align:center;">
                        <i class="fa fa-check-circle"
                           style="font-size:40px;color:#28a745;
                                  display:block;margin-bottom:10px;"></i>
                        <h6 style="color:#155724;font-weight:700;margin:0 0 5px;">
                            Hóa Đơn Đã Được Thanh Toán
                        </h6>
                        <p style="color:#155724;font-size:13px;margin:0;">
                            Cảm ơn bạn đã thanh toán đúng hạn!
                        </p>
                    </div>
                }

                <a href="@Url.Action("DanhSach","HoaDon")"
                   style="display:inline-block;padding:11px 25px;
                          border:1px solid #2cbdb8;color:#2cbdb8;
                          border-radius:8px;text-decoration:none;
                          font-weight:600;font-size:14px;">
                    <i class="fa fa-arrow-left mr-2"></i>
                    Quay Lại Danh Sách
                </a>

            </div>
        </div>
    </div>
</section>

<script>
    function hienThiTenFile(input) {
        if (input.files && input.files[0]) {
            var el = document.getElementById('tenFileDaChon');
            el.textContent = '✓ Đã chọn: ' + input.files[0].name;
            el.style.display = 'block';
        }
    }
    setTimeout(function () {
        $('.alert').fadeOut('slow', function () { $(this).remove(); });
    }, 3000);
</script>