@model HappyHouse.Models.ChiSoDienNuoc

@{
    ViewBag.Title = "Sua chi so";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    bool laDien = Model.LoaiDichVu == "Dien";
    var khach = Model.HopDong?.NguoiDung1;
    var phong = Model.HopDong?.PhongTro;
    var toaNha = phong?.ToaNha;
}

@section breadTitle {
    <h2 style="font-weight:bold;color:black">
        Chỉ số điện nước
    </h2>
}
@section breadLink {
    <a href="@Url.Action("DanhSach","ChuTroChiSo")">
        Danh sách chỉ số
    </a>
}

<div class="card shadow-sm mb-4">
    <div class="card-header font-weight-bold text-primary">
        <i class="fa fa-info-circle mr-2"></i>
        Thông tin
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <small class="text-muted">Phòng</small>
                <p class="font-weight-bold mb-0">
                    @(phong != null
                        ? "Phòng " + phong.SoPhong
                          + " — " + toaNha?.TenToaNha
                        : "—")
                </p>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Khách hàng</small>
                <p class="font-weight-bold mb-0">
                    @(khach?.HoTen ?? "—")
                </p>
                <small class="text-muted">
                    @(khach?.SoDienThoai ?? "")
                </small>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Tháng ghi</small>
                <p class="font-weight-bold mb-0">
                    @Model.ThangGhi.ToString("MM/yyyy")
                </p>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Loại</small>
                <p class="mb-0">
                    @if (laDien)
                    {
                        <span class="badge badge-warning
                                     px-2 py-1">
                            <i class="fa fa-bolt mr-1"></i>Điện
                        </span>
                    }
                    else
                    {
                        <span class="badge badge-info
                                     px-2 py-1">
                            <i class="fa fa-tint mr-1"></i>Nước
                        </span>
                    }
                </p>
            </div>
        </div>
    </div>
</div>

@using (Html.BeginForm("SuaThongTin", "ChuTroChiSo",
    FormMethod.Post,
    new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="MaChiSo"
           value="@Model.MaChiSo" />
    <input type="hidden" name="LoaiDichVu"
           value="@Model.LoaiDichVu" />
    <input type="hidden" name="MaHopDong"
           value="@Model.MaHopDong" />

    <div class="card @(laDien ? "border-warning" : "border-info") shadow-sm mb-4">
        <div class="card-header @(laDien ? "bg-warning" : "bg-info") text-white font-weight-bold">
            <i class="fa @(laDien ? "fa-bolt" : "fa-tint") mr-2"></i>
            Sửa chỉ số @(laDien ? "ĐIỆN" : "NƯỚC")
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Tháng ghi
                        </label>
                        <input type="month" name="ThangGhi"
                               class="form-control"
                               value="@Model.ThangGhi
                                          .ToString(" yyyy-MM")" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Chỉ số đầu
                        </label>
                        <input type="number" name="ChiSoDau"
                               id="chiSoDau"
                               class="form-control calc"
                               value="@Model.ChiSoDau"
                               min="0" step="1" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Chỉ số cuối
                            <span class="text-danger">*</span>
                        </label>
                        <input type="number" name="ChiSoCuoi"
                               id="chiSoCuoi"
                               class="form-control calc"
                               value="@Model.ChiSoCuoi"
                               min="0" step="1" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label class="font-weight-bold">
                            Đơn giá (đ/@(laDien ? "kWh" : "m³"))
                            <span class="text-danger">*</span>
                        </label>
                        <input type="number" name="DonGia"
                               id="donGia"
                               class="form-control calc"
                               value="@Model.DonGia"
                               min="0" step="100" />
                    </div>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-md-4">
                    <div class="alert alert-secondary py-2 mb-0">
                        <small class="text-muted d-block">
                            Tiêu thụ
                        </small>
                        <strong id="lblTieuThu">
                            @(Model.SoTieuThu.HasValue
                                ? String.Format("{0:N0}",
                                    Model.SoTieuThu.Value)
                                : "0")
                            @(laDien ? "kWh" : "m³")
                        </strong>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="alert alert-success py-2 mb-0">
                        <small class="text-muted d-block">
                            Thành tiền
                        </small>
                        <strong id="lblThanhTien"
                                class="text-success">
                            @(Model.ThanhTien.HasValue
                                ? String.Format("{0:N0}",
                                    Model.ThanhTien.Value)
                                : "0")đ
                        </strong>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-0">
                        <label class="font-weight-bold
                                      small">
                            Ảnh đồng hồ mới
                            <span class="text-muted
                                         font-weight-normal">
                                (để trống = giữ cũ)
                            </span>
                        </label>
                        <input type="file" name="anhMoi"
                               class="form-control-file"
                               accept="image/*"
                               onchange="previewAnh(this)" />
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.AnhDongHo))
            {
                <div class="mt-3">
                    <small class="text-muted">
                        Ảnh hiện tại:
                    </small>
                    <br />
                    <img id="prevAnh"
                         src="~/Content/images/dongho/@Model.AnhDongHo"
                         style="width:120px;height:100px;
                                object-fit:cover;
                                border-radius:6px;
                                border:1px solid #dee2e6;
                                margin-top:4px;" />
                </div>
            }
            else
            {
                <img id="prevAnh" src="#"
                     style="display:none;width:120px;
                            height:100px;object-fit:cover;
                            border-radius:6px;
                            border:1px solid #dee2e6;
                            margin-top:8px;" />
            }

        </div>
    </div>

    <div class="d-flex justify-content-between">
        @Html.ActionLink("Trở lại", "DanhSach", null,
            new { @class = "btn btn-secondary px-4" })
        <button type="submit"
                class="btn btn-primary px-4">
            <i class="fa fa-save mr-1"></i>
            Lưu thay đổi
        </button>
    </div>
}

@section Scripts {
    <script>
var laDien = @(laDien ? "true" : "false");

function tinhToan() {
    var dau   = parseFloat($('#chiSoDau').val())  || 0;
    var cuoi  = parseFloat($('#chiSoCuoi').val()) || 0;
    var gia   = parseFloat($('#donGia').val())     || 0;
    var tieu  = Math.max(0, cuoi - dau);
    var tien  = tieu * gia;

    $('#lblTieuThu').text(
        tieu.toLocaleString('vi-VN')
        + (laDien ? ' kWh' : ' m³'));
    $('#lblThanhTien').text(
        tien.toLocaleString('vi-VN') + 'đ');
}

$('.calc').on('input', tinhToan);

function previewAnh(input) {
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function (e) {
            $('#prevAnh')
                .attr('src', e.target.result)
                .show();
        };
        reader.readAsDataURL(input.files[0]);
    }
}
    </script>
}