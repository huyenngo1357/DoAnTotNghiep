@model HappyHouse.Models.NguoiDung

@{
    ViewBag.Title = "Cài đặt QR thanh toán";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@section breadTitle {
    <h2 style="font-weight:bold; color:black">Cài đặt QR thanh toán</h2>
}
@section breadLink {
    <a href="@Url.Action("DanhSach","ChuTroThanhToan")">Xác nhận thanh toán</a>
}

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header font-weight-bold text-primary">
                <i class="fa fa-cog mr-2"></i>
                Thông tin tài khoản nhận tiền
            </div>
            <div class="card-body">

                <div class="alert alert-info small">
                    <i class="fa fa-info-circle mr-2"></i>
                    Thông tin này sẽ hiển thị cho khách hàng khi họ thanh toán hóa đơn.
                    Hãy điền chính xác để tránh nhầm lẫn.
                </div>

                @using (Html.BeginForm("CaiDatQR", "ChuTroThanhToan",
                    FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label class="font-weight-bold">Ngân hàng / Ví điện tử</label>
                        <input type="text" name="tenNganHang"
                               class="form-control"
                               value="@Model.TenNganHang"
                               placeholder="VD: Vietcombank, MB Bank, MoMo, ZaloPay..." />
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Số tài khoản / Số điện thoại</label>
                        <input type="text" name="soTaiKhoan"
                               class="form-control"
                               value="@Model.SoTaiKhoan"
                               placeholder="VD: 1234567890 hoặc 0901234567" />
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Tên chủ tài khoản</label>
                        <input type="text" name="tenTaiKhoan"
                               class="form-control"
                               value="@Model.TenTaiKhoan"
                               placeholder="VD: NGUYEN VAN A (viết hoa không dấu)" />
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">
                            Ảnh mã QR
                            @if (!string.IsNullOrEmpty(Model?.AnhQR))
                            {
                                <span class="text-muted font-weight-normal">
                                    (để trống nếu không muốn thay đổi)
                                </span>
                            }
                        </label>
                        <input type="file" name="anhQR" id="inputQR"
                               class="form-control-file"
                               accept="image/*"
                               onchange="previewQR(this)" />
                        <small class="text-muted d-block mt-1">
                            <i class="fa fa-lightbulb mr-1 text-warning"></i>
                            Vào app ngân hàng → Nhận tiền → Lưu mã QR → Upload lên đây.
                        </small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="@Url.Action("DanhSach")"
                           class="btn btn-secondary px-4">
                            Trở lại
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fa fa-save mr-1"></i> Lưu cài đặt
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header font-weight-bold text-primary">
                <i class="fa fa-eye mr-2"></i>
                Xem trước — Khách thấy gì
            </div>
            <div class="card-body text-center">

                <div id="qrContainer">
                    @if (Model != null && !string.IsNullOrEmpty(Model.AnhQR))
                    {
                        <img id="previewQRImg"
                             src="~/Content/images/qr/@Model.AnhQR"
                             style="max-width:200px;border-radius:8px;
                                    border:3px solid #4e73df;" />
                    }
                    else
                    {
                        <img id="previewQRImg" src="#"
                             style="display:none;max-width:200px;
                                    border-radius:8px;border:3px solid #4e73df;" />
                        <div id="placeholderQR"
                             class="bg-light rounded d-flex align-items-center
                                    justify-content-center mx-auto"
                             style="width:200px;height:200px;">
                            <div class="text-muted text-center">
                                <i class="fa fa-qrcode fa-3x d-block mb-2"></i>
                                Chưa có mã QR
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-3" id="infoPreview">
                    @if (Model != null && !string.IsNullOrEmpty(Model.TenNganHang))
                    {
                        <p class="mb-1 font-weight-bold">@Model.TenNganHang</p>
                        <p class="mb-1">
                            <span class="badge badge-light border px-3 py-1"
                                  style="font-size:14px">
                                @Model.SoTaiKhoan
                            </span>
                        </p>
                        <p class="mb-0 text-muted small">@Model.TenTaiKhoan</p>
                    }
                    else
                    {
                        <p class="text-muted small">
                            Điền thông tin bên trái để xem trước
                        </p>
                    }
                </div>

                <hr />
                <small class="text-muted">
                    <i class="fa fa-info-circle mr-1"></i>
                    Đây là giao diện khách hàng sẽ thấy khi thanh toán hóa đơn
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    function previewQR(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                $('#previewQRImg').attr('src', e.target.result).show();
                $('#placeholderQR').hide();
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
    </script>
}