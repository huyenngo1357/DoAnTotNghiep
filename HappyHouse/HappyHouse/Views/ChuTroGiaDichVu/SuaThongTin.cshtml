@model HappyHouse.Models.GiaDichVu

@{
    ViewBag.Title = "Sửa giá dịch vụ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@section breadTitle {
    <h2 style="font-weight:bold;color:black">Giá dịch vụ</h2>
}
@section breadLink {
    <a href="@Url.Action("DanhSach","ChuTroGiaDichVu")">Danh sách</a>
}

@using (Html.BeginForm("SuaThongTin", "ChuTroGiaDichVu", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="MaGiaDichVu" value="@Model.MaGiaDichVu" />

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Tòa nhà</label>
                <input type="text" class="form-control" readonly
                       value="@(Model.ToaNha?.TenToaNha ?? "")" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label class="font-weight-bold">Loại dịch vụ</label>
                <div class="form-control bg-light">
                    @if (Model.TienIch != null)
                    {
                        <i class="fas @Model.TienIch.BieuTuong
                                   mr-2 text-warning"></i>
                        @Model.TienIch.TenTienIch
                    }
                </div>
                <small class="text-muted">
                    Không thể thay đổi loại dịch vụ sau khi tạo.
                </small>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label class="font-weight-bold">Tên hiển thị</label>
                @Html.TextBoxFor(m => m.TenDichVu, new
                {
                    @class = "form-control",
                    maxlength = "100"
                })
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                <label class="font-weight-bold">
                    Đơn giá (đ) <span class="text-danger">*</span>
                </label>
                <div class="input-group">
                    @Html.TextBoxFor(m => m.DonGia, new
                    {
                        @class = "form-control",
                        type = "number",
                        min = "0",
                        step = "1000"
                    })
                    <div class="input-group-append">
                        <span class="input-group-text">đ</span>
                    </div>
                </div>
                @Html.ValidationMessageFor(m => m.DonGia, "",
                    new { @class = "text-danger small" })
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                <label class="font-weight-bold">Đơn vị tính</label>
                @Html.TextBoxFor(m => m.DonVi, new
                {
                    @class = "form-control",
                    maxlength = "30"
                })
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label class="font-weight-bold">Ngày áp dụng</label>
                @Html.TextBoxFor(m => m.NgayApDung, "{0:yyyy-MM-dd}", new
                {
                    @class = "form-control",
                    type = "date"
                })
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                <label class="font-weight-bold">
                    Ngày kết thúc
                    <span class="text-muted font-weight-normal">
                        (không bắt buộc)
                    </span>
                </label>
                @Html.TextBoxFor(m => m.NgayKetThuc, "{0:yyyy-MM-dd}", new
                {
                    @class = "form-control",
                    type = "date"
                })
                @Html.ValidationMessageFor(m => m.NgayKetThuc, "",
                    new { @class = "text-danger small" })
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between mt-2">
        @Html.ActionLink("Trở lại", "DanhSach", null,
            new { @class = "btn btn-secondary px-4" })
        <button type="submit" class="btn btn-warning px-4">
            <i class="fa fa-save mr-1"></i> Lưu thay đổi
        </button>
    </div>
}