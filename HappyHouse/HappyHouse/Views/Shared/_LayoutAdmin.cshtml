        <!-- ══════════════════════════════════════════
             CONTENT WRAPPER
        ══════════════════════════════════════════ -->
        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">

                <!-- Topbar -->
                <nav class="navbar navbar-expand navbar-light bg-white topbar shadow">
                    <form class="form-inline">
                        <button id="sidebarToggleTop"
                                class="btn btn-link d-md-none rounded-circle mr-3">
                            <i class="fa fa-bars"></i>
                        </button>
                    </form>

                    <ul class="navbar-nav ml-auto">

                        @if (isAdmin && tongThongBaoAdmin > 0)
                        {
                            <li class="nav-item dropdown no-arrow mx-1">
                                <a class="nav-link dropdown-toggle" href="#"
                                   role="button" data-toggle="dropdown">
                                    <i class="fas fa-bell fa-fw"></i>
                                    <span class="badge badge-danger badge-counter">
                                        @tongThongBaoAdmin
                                    </span>
                                </a>
                                <div class="dropdown-list dropdown-menu
                                        dropdown-menu-right shadow
                                        animated--grow-in">
                                    <h6 class="dropdown-header">Thông Báo Admin</h6>

                                    @if (soToaNhaChoDuyet > 0)
                                    {
                                        <a class="dropdown-item d-flex align-items-center"
                                           href="@Url.Action("DanhSach","AdminToaNha",
                                           new { trangThaiDuyet = "ChoDuyet" })">
                                            <div class="mr-3">
                                                <div class="icon-circle bg-warning">
