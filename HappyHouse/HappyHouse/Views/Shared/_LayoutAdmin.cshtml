                                            </div>
                                            <div>
                                                <div class="small text-gray-500">
                                                    Tòa nhà chờ duyệt
                                                </div>
                                                <span class="font-weight-bold">
                                                    @soToaNhaChoDuyet tòa nhà mới
                                                </span>
                                            </div>
                                        </a>
                                    }

                                    @if (soYeuCauXoa > 0)
                                    {
