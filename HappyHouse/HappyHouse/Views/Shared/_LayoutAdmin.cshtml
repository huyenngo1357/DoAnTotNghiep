@{
    var userLayout = Session["UserOnline"] as HappyHouse.Models.NguoiDung;
    bool isAdmin = userLayout != null && userLayout.MaVaiTro == "CHUTHAU";
    bool isChuTro = userLayout != null && userLayout.MaVaiTro == "CHUTRO";

    // Lấy ảnh đại diện
    string anhDaiDien = userLayout?.AnhDaiDien;

    // Badge chủ trọ: biên lai chờ xác nhận
    int soChoXN = 0;
    if (isChuTro && userLayout != null)
    {
        try
        {
            soChoXN = new HappyHouse.Models.ThanhToanBusiness()
                          .DemChoXacNhan(userLayout.MaNguoiDung);
        }
        catch { }
    }

    // Badge admin: tòa nhà chờ duyệt + yêu cầu xóa
    int soToaNhaChoDuyet = 0;
    int soYeuCauXoa = 0;
    if (isAdmin)
    {
        try
        {
            var db = HappyHouse.Models.DataProvider.Entities;
            soToaNhaChoDuyet = db.ToaNhas
                .Count(x => x.TrangThaiDuyet == "ChoDuyet"
                          && x.TrangThai == true);
            soYeuCauXoa = db.ToaNhas
                .Count(x => x.TrangThaiDuyet == "YeuCauXoa"
                          && x.TrangThai == true);
        }
        catch { }
    }

    int tongThongBaoAdmin = soToaNhaChoDuyet + soYeuCauXoa;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewBag.Title - HappyHouse</title>

    <link href="~/Content/Admin/vendor/fontawesome-free/css/all.min.css"
