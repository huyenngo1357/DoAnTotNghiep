                        <span>
                            Thanh Toán
                            @if (soChoXN > 0)
                            {
                                <span class="badge badge-danger badge-counter ml-1"
                                      style="font-size:10px">
                                    @soChoXN
                                </span>
                            }
                        </span>
                    </a>
                    <div id="collapseCTThanhToan" class="collapse"
                         data-parent="#accordionSidebar">
