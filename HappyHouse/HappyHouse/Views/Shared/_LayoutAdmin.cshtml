                                           href="@Url.Action("DanhSach","AdminToaNha",
                                           new { trangThaiDuyet = "YeuCauXoa" })">
                                            <div class="mr-3">
                                                <div class="icon-circle bg-danger">
                                                    <i class="fas fa-trash text-white"></i>
                                                </div>
                                            </div>
                                            <div>
                                                <div class="small text-gray-500">
                                                    Yêu cầu xóa tòa nhà
                                                </div>
                                                <span class="font-weight-bold">
                                                    @soYeuCauXoa yêu cầu chờ xử lý
                                                </span>
                                            </div>
                                        </a>
                                    }
                                </div>
                            </li>
                        }

                        @if (isChuTro && soChoXN > 0)
                        {
                            <li class="nav-item dropdown no-arrow mx-1">
                                <a class="nav-link dropdown-toggle" href="#"
                                   role="button" data-toggle="dropdown">
                                    <i class="fas fa-bell fa-fw"></i>
                                    <span class="badge badge-danger badge-counter">
                                        @soChoXN
                                    </span>
                                </a>
                                <div class="dropdown-list dropdown-menu
                                        dropdown-menu-right shadow
                                        animated--grow-in">
                                    <h6 class="dropdown-header">Thông Báo</h6>
                                    <a class="dropdown-item d-flex align-items-center"
                                       href="@Url.Action("DanhSach","ChuTroThanhToan")">
                                        <div class="mr-3">
                                            <div class="icon-circle bg-warning">
                                                <i class="fas fa-receipt text-white"></i>
                                            </div>
                                        </div>
                                        <div>
                                            <div class="small text-gray-500">
                                                Biên lai thanh toán
                                            </div>
                                            <span class="font-weight-bold">
                                                @soChoXN biên lai chờ xác nhận
