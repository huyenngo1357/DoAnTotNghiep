@using System.Collections.Generic
@using HappyHouse.Models
@using PagedList.Mvc
@model PagedList.IPagedList<HappyHouse.Models.PhongTro>

@{
    ViewBag.Title = "Danh Sách Phòng Trọ";
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
    ViewBag.ActiveMenu = "PhongTro";

    var dsTinhThanh = ViewBag.DsTinhThanh as List<string>
                       ?? new List<string>();
    var dsPhuongXa = ViewBag.DsPhuongXa as List<string>
                       ?? new List<string>();
    var dsNoiBat = ViewBag.DsPhongNoiBat as List<PhongTro>
                       ?? new List<PhongTro>();

    string tinhDangChon = ViewBag.TinhThanh as string ?? "";
    string phuongDangChon = ViewBag.PhuongXa as string ?? "";
}

<style>
    /* ── Search bar ── */
    .hh-search-wrap {
        background: linear-gradient(135deg,#1a1a2e 0%,#2d2d44 100%);
        padding: 28px 0;
    }

    .hh-search-label {
        font-size: 11px;
        font-weight: 700;
        color: #2cbdb8;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 5px;
        display: block;
    }

    .hh-search-input {
        width: 100%;
        height: 42px;
        padding: 0 13px;
        border: none;
        border-radius: 6px;
        font-size: 13px;
        background: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,.18);
        outline: none;
    }

        .hh-search-input:disabled {
            background: #e0e0e0;
            cursor: not-allowed;
        }

    .hh-btn-search {
        width: 100%;
        height: 42px;
        background: #2cbdb8;
        color: #fff;
        font-weight: 700;
        font-size: 14px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        letter-spacing: .4px;
        transition: background .2s;
    }

        .hh-btn-search:hover {
            background: #24a09b;
        }

    .hh-btn-reset {
        width: 100%;
        height: 42px;
        background: transparent;
        color: #fff;
        font-weight: 600;
        font-size: 13px;
        border: 1px solid rgba(255,255,255,.35);
        border-radius: 6px;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: background .2s;
    }

        .hh-btn-reset:hover {
            background: rgba(255,255,255,.1);
            color: #fff;
            text-decoration: none;
        }

    /* ── Card phòng ── */
    .room-card {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(0,0,0,.08);
        margin-bottom: 24px;
        transition: transform .2s, box-shadow .2s;
    }

        .room-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 28px rgba(0,0,0,.13);
        }

    .room-card-img {
        width: 100%;
        height: 210px;
        object-fit: cover;
        display: block;
    }

    .room-card-body {
        padding: 16px 18px;
    }

    .room-card-tag {
        display: inline-block;
        background: #e8faf9;
        color: #2cbdb8;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: 8px;
        letter-spacing: .4px;
    }

    .room-card-title {
        font-size: 15px;
        font-weight: 700;
        color: #222;
        margin: 0 0 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .room-card-addr {
        font-size: 12px;
        color: #888;
        margin-bottom: 10px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .room-card-price {
        font-size: 18px;
        font-weight: 800;
        color: #2cbdb8;
        margin-bottom: 10px;
    }

        .room-card-price span {
            font-size: 12px;
            color: #aaa;
            font-weight: 400;
        }

    .room-card-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        font-size: 12px;
        color: #666;
        border-top: 1px solid #f0f0f0;
        padding-top: 10px;
        margin-bottom: 12px;
    }

        .room-card-meta i {
            color: #2cbdb8;
            margin-right: 3px;
        }

    .room-card-ti {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 12px;
    }

        .room-card-ti span {
            font-size: 11px;
            padding: 2px 8px;
            background: #f5f5f5;
            border-radius: 3px;
            color: #555;
        }

    .room-card-btn {
        display: block;
        text-align: center;
        padding: 9px;
        background: #2cbdb8;
        color: #fff;
        border-radius: 6px;
        font-weight: 700;
        font-size: 13px;
        text-decoration: none;
        transition: background .2s;
    }

        .room-card-btn:hover {
            background: #24a09b;
            color: #fff;
            text-decoration: none;
        }

    /* ── Sidebar ── */
    .hh-sidebar-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 16px rgba(0,0,0,.07);
        padding: 20px;
        margin-bottom: 24px;
    }

    .hh-sidebar-title {
        font-size: 15px;
        font-weight: 700;
        color: #222;
        margin: 0 0 16px;
        padding-bottom: 10px;
        border-bottom: 2px solid #2cbdb8;
    }

    /* ── Phân trang ── */
    .hh-pager {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 24px;
    }

        .hh-pager a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 6px;
            border: 1px solid #ddd;
            color: #555;
            font-size: 14px;
            text-decoration: none;
            transition: .15s;
        }

            .hh-pager a:hover, .hh-pager a.active {
                background: #2cbdb8;
                border-color: #2cbdb8;
                color: #fff;
                text-decoration: none;
            }

            .hh-pager a.active {
                pointer-events: none;
                font-weight: 700;
            }
</style>

@* ── Search Bar ── *@
<div class="hh-search-wrap">
    <div class="container-fluid" style="max-width:1400px;">
        <form action="@Url.Action("DanhSach","PhongTro")" method="get">
            <div class="row" style="margin-bottom:8px;">

                <div class="col-lg-4 col-md-12" style="margin-bottom:8px;">
                    <label class="hh-search-label">
                        <i class="fa fa-search mr-1"></i>Tên phòng / Tòa nhà
                    </label>
                    <input class="hh-search-input" type="text" name="tuKhoa"
                           value="@ViewBag.TuKhoa"
                           placeholder="VD: Phòng A01, Nhà trọ Bình Minh..." />
                </div>

                <div class="col-lg-3 col-md-6" style="margin-bottom:8px;">
                    <label class="hh-search-label">
                        <i class="fa fa-map-marker mr-1"></i>Tỉnh / Thành phố
                    </label>
                    <select class="hh-search-input" name="tinhThanh"
                            id="selTinhThanh" style="cursor:pointer;">
                        <option value="">-- Tất cả --</option>
                        @foreach (var t in dsTinhThanh)
                        {
                            <option value="@t"
                                    @(tinhDangChon == t ? "selected" : "")>
                                @t
                            </option>
                        }
                    </select>
                </div>

                <div class="col-lg-3 col-md-6" style="margin-bottom:8px;">
                    <label class="hh-search-label">
                        <i class="fa fa-map-o mr-1"></i>Phường / Xã
                    </label>
                    <select class="hh-search-input" name="phuongXa"
                            id="selPhuongXa"
                            @(string.IsNullOrEmpty(tinhDangChon) ? "disabled" : "")
                            style="cursor:@(string.IsNullOrEmpty(tinhDangChon)
                                ? "not-allowed" : "pointer");">
                        <option value="">-- Tất cả --</option>
                        @foreach (var px in dsPhuongXa)
                        {
                            <option value="@px"
                                    @(phuongDangChon == px ? "selected" : "")>
                                @px
                            </option>
                        }
                    </select>
                </div>

                <div class="col-lg-2 col-md-6 d-flex align-items-end"
                     style="margin-bottom:8px;">
                    <button type="submit" class="hh-btn-search"
                            style="font-size:15px;">
                        <i class="fa fa-search mr-2"></i>Tìm Kiếm
                    </button>
                </div>

            </div>

            <div class="row align-items-end">

                <div class="col-lg-3 col-md-6" style="margin-bottom:8px;">
                    <label class="hh-search-label">
                        <i class="fa fa-arrow-down mr-1"></i>Giá min (đ)
                    </label>
                    <input class="hh-search-input" type="number"
                           name="giaMin" min="0" step="100000"
                           value="@ViewBag.GiaMin"
                           placeholder="VD: 1.000.000" />
                </div>

                <div class="col-lg-3 col-md-6" style="margin-bottom:8px;">
                    <label class="hh-search-label">
                        <i class="fa fa-arrow-up mr-1"></i>Giá max (đ)
                    </label>
                    <input class="hh-search-input" type="number"
                           name="giaMax" min="0" step="100000"
                           value="@ViewBag.GiaMax"
                           placeholder="VD: 5.000.000" />
                </div>

                <div class="col-lg-2 col-md-6" style="margin-bottom:8px;">
                    <label class="hh-search-label">
                        <i class="fa fa-expand mr-1"></i>Diện tích min (m²)
                    </label>
                    <input class="hh-search-input" type="number"
                           name="dienTichMin" min="0" step="1"
                           value="@ViewBag.DienTichMin"
                           placeholder="VD: 15" />
                </div>

                <div class="col-lg-2 col-md-6" style="margin-bottom:8px;">
                    <label class="hh-search-label">
                        <i class="fa fa-users mr-1"></i>Số người được ở (≥)
                    </label>
                    <input class="hh-search-input" type="number"
                           name="soNguoi" min="1" step="1"
                           value="@ViewBag.SoNguoi"
                           placeholder="VD: 2" />
                </div>

                <div class="col-lg-2 col-md-6 d-flex align-items-end"
                     style="margin-bottom:8px;">
                    <a href="@Url.Action("DanhSach","PhongTro")"
                       class="hh-btn-reset" style="width:100%;">
                        <i class="fa fa-refresh mr-1"></i>Xóa bộ lọc
                    </a>
                </div>

            </div>

        </form>
    </div>
</div>

@* ── Kết quả ── *@
@* ── Kết quả ── *@
<section style="padding:36px 0 60px;background:#f7f8fa;">
    <div class="container-fluid" style="max-width:1400px;">
        <div style="font-size:13px;color:#888;margin-bottom:20px;">
            <a href="@Url.Action("Index","TrangChu")"
               style="color:#2cbdb8;text-decoration:none;">
                Trang chủ
            </a>
            <i class="fa fa-angle-right mx-2"></i>
            <span style="color:#555;font-weight:600;">Phòng trọ</span>
            @if (!string.IsNullOrEmpty(tinhDangChon))
            {
                <i class="fa fa-angle-right mx-2"></i>
                <span style="color:#555;">@tinhDangChon</span>
            }
            @if (!string.IsNullOrEmpty(phuongDangChon))
            {
                <i class="fa fa-angle-right mx-2"></i>
                <span style="color:#555;">@phuongDangChon</span>
            }
            @if (!string.IsNullOrEmpty(ViewBag.TuKhoa as string))
            {
                <i class="fa fa-angle-right mx-2"></i>
                <span style="color:#555;">
                    "@ViewBag.TuKhoa"
                </span>
            }
        </div>

        <div class="row">
            @* ── Danh sách (9 cột) ── *@
            <div class="col-lg-9">

                <div class="d-flex justify-content-between align-items-center
                             mb-3">
                    <h5 style="font-weight:700;margin:0;color:#222;">
                        Phòng trọ
                        @if (!string.IsNullOrEmpty(tinhDangChon))
                        {
                            <span style="color:#2cbdb8;">— @tinhDangChon</span>
                        }
                    </h5>
                    <span style="font-size:13px;color:#888;">
                        <strong style="color:#2cbdb8;">
                            @ViewBag.TongKetQua
                        </strong> kết quả
                    </span>
                </div>

                @if (!Model.Any())
                {
                    <div style="text-align:center;padding:80px 0;
                                background:#fff;border-radius:10px;">
                        <i class="fa fa-home"
                           style="font-size:60px;color:#ddd;
                                  display:block;margin-bottom:20px;"></i>
                        <h5 style="color:#999;">
                            Không tìm thấy phòng nào phù hợp.
                        </h5>
                        <a href="@Url.Action("DanhSach","PhongTro")"
                           style="color:#2cbdb8;">
                            Xem tất cả phòng
                        </a>
                    </div>
                }
                else
                {
                    <div class="row">
                        @foreach (var phong in Model)
                        {
                            var dsAnh = phong.HinhAnhPhongs.ToList();
                            var anh = dsAnh.FirstOrDefault(
                                            x => x.LaDaiDien && x.TrangThai)
                                        ?? dsAnh.FirstOrDefault(x => x.TrangThai);
                            string anhUrl = anh != null
                                ? Url.Content("~/Content/images/phongs/"
                                              + anh.TenFile)
                                : "/Content/Home/img/properties/property-1.jpg";

                            <div class="col-lg-6 col-md-6">
                                <div class="room-card">
                                    <a href="@Url.Action("ChiTiet","PhongTro",
                                               new { maPhong = phong.MaPhong })">
                                        <img class="room-card-img"
                                             src="@anhUrl"
                                             alt="Phòng @phong.SoPhong" />
                                    </a>
                                    <div class="room-card-body">
                                        <span class="room-card-tag">
                                            Còn trống
                                        </span>
                                        <div class="room-card-title">
                                            Phòng @phong.SoPhong
                                            @if (phong.ToaNha != null)
                                            {
                                                <span style="font-weight:400;
                                                             color:#888;">
                                                    — @phong.ToaNha.TenToaNha
                                                </span>
                                            }
                                        </div>
                                        <div class="room-card-addr">
                                            <i class="fa fa-map-marker mr-1"
                                               style="color:#2cbdb8;"></i>
                                            @(phong.ToaNha != null
                                                ? phong.ToaNha.DiaChi + ", "
                                                  + phong.ToaNha.TinhThanh
                                                : "—")
                                        </div>
                                        <div class="room-card-price">
                                            @String.Format("{0:N0}", phong.GiaThue)đ
                                            <span>/tháng</span>
                                        </div>
                                        <div class="room-card-meta">
                                            <span>
                                                <i class="fa fa-expand"></i>
                                                @(phong.DienTich.HasValue
                                                    ? phong.DienTich.Value + " m²"
                                                    : "—")
                                            </span>
                                            <span>
                                                <i class="fa fa-users"></i>
                                                @phong.SoNguoiToiDa người
                                            </span>
                                            <span>
                                                <i class="fa fa-building-o"></i>
                                                Tầng @phong.Tang
                                            </span>
                                            <span>
                                                <i class="fa fa-money"></i>
                                                @(phong.TienCoc.HasValue
                                                    ? "Cọc " + String.Format(
                                                        "{0:N0}", phong.TienCoc) + "đ"
                                                    : "Không cọc")
                                            </span>
                                        </div>
                                        @if (phong.TienIches != null
                                          && phong.TienIches.Any())
                                        {
                                            <div class="room-card-ti">
                                                @foreach (var ti in
                                                    phong.TienIches.Take(4))
                                                {
                                                    <span>@ti.TenTienIch</span>
                                                }
                                                @if (phong.TienIches.Count > 4)
                                                {
                                                    <span>
                                                        +@(phong.TienIches.Count - 4)
                                                    </span>
                                                }
                                            </div>
                                        }
                                        <a class="room-card-btn"
                                           href="@Url.Action("ChiTiet","PhongTro",
                                                  new { maPhong = phong.MaPhong })">
                                            Xem Chi Tiết
                                            <i class="fa fa-arrow-right ml-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @* Phân trang *@
                    if (Model.PageCount > 1)
                    {
                        <div class="hh-pager">
                            @if (Model.HasPreviousPage)
                            {
                                <a href="@Url.Action("DanhSach", new {
                                    page        = Model.PageNumber - 1,
                                    tuKhoa      = ViewBag.TuKhoa,
                                    tinhThanh   = ViewBag.TinhThanh,
                                    phuongXa    = ViewBag.PhuongXa,
                                    giaMin      = ViewBag.GiaMin,
                                    giaMax      = ViewBag.GiaMax,
                                    dienTichMin = ViewBag.DienTichMin,
                                    soNguoi     = ViewBag.SoNguoi })">
                                    <i class="fa fa-angle-left"></i>
                                </a>
                            }
                            @for (int i = 1; i <= Model.PageCount; i++)
                            {
                                <a class="@(i == Model.PageNumber ? "active" : "")"
                                   href="@(i == Model.PageNumber ? "#" :
                                    Url.Action("DanhSach", new {
                                        page        = i,
                                        tuKhoa      = ViewBag.TuKhoa,
                                        tinhThanh   = ViewBag.TinhThanh,
                                        phuongXa    = ViewBag.PhuongXa,
                                        giaMin      = ViewBag.GiaMin,
                                        giaMax      = ViewBag.GiaMax,
                                        dienTichMin = ViewBag.DienTichMin,
                                        soNguoi     = ViewBag.SoNguoi }))">
                                    @i
                                </a>
                            }
                            @if (Model.HasNextPage)
                            {
                                <a href="@Url.Action("DanhSach", new {
                                    page        = Model.PageNumber + 1,
                                    tuKhoa      = ViewBag.TuKhoa,
                                    tinhThanh   = ViewBag.TinhThanh,
                                    phuongXa    = ViewBag.PhuongXa,
                                    giaMin      = ViewBag.GiaMin,
                                    giaMax      = ViewBag.GiaMax,
                                    dienTichMin = ViewBag.DienTichMin,
                                    soNguoi     = ViewBag.SoNguoi })">
                                    <i class="fa fa-angle-right"></i>
                                </a>
                            }
                        </div>
                    }
                }
            </div>

            @* ── Sidebar (3 cột) ── *@
            <div class="col-lg-3">

                <div class="hh-sidebar-card">
                    <h5 class="hh-sidebar-title">
                        <i class="fa fa-star mr-2"
                           style="color:#2cbdb8;"></i>Phòng Nổi Bật
                    </h5>
                    @foreach (var p in dsNoiBat)
                    {
                        var dsAnhP = p.HinhAnhPhongs.ToList();
                        var anhP = dsAnhP.FirstOrDefault(
                                         x => x.LaDaiDien && x.TrangThai)
                                     ?? dsAnhP.FirstOrDefault(x => x.TrangThai);
                        string anhPUrl = anhP != null
                            ? Url.Content("~/Content/images/phongs/"
                                          + anhP.TenFile)
                            : "/Content/Home/img/properties/best-agent-1.jpg";

                        <a href="@Url.Action("ChiTiet","PhongTro",
                                   new { maPhong = p.MaPhong })"
                           style="display:flex;gap:12px;margin-bottom:14px;
                                  padding-bottom:14px;
                                  border-bottom:1px solid #f0f0f0;
                                  text-decoration:none;">
                            <img src="@anhPUrl" alt=""
                                 style="width:72px;height:60px;
                                        object-fit:cover;border-radius:6px;
                                        flex-shrink:0;" />
                            <div>
                                <div style="font-size:13px;font-weight:700;
                                            color:#222;margin-bottom:2px;">
                                    Phòng @p.SoPhong
                                </div>
                                <div style="font-size:11px;color:#888;
                                            margin-bottom:4px;">
                                    @(p.ToaNha?.TenToaNha ?? "")
                                </div>
                                <div style="font-size:13px;font-weight:700;
                                            color:#2cbdb8;">
                                    @String.Format("{0:N0}", p.GiaThue)đ
                                </div>
                            </div>
                        </a>
                    }
                </div>

            </div>

        </div>
    </div>
</section>

@section Scripts {
    <script>
var urlPhuongXa = '@Url.Action("LayPhuongXa","PhongTro")';

function loadPhuongXa(tinh, phuongChon) {
    var selPX = $('#selPhuongXa');

    if (!tinh) {
        selPX.prop('disabled', true)
             .css({ background: '#e0e0e0', cursor: 'not-allowed' })
             .html('<option value="">-- Tất cả --</option>');
        return;
    }

    selPX.html('<option value="">Đang tải...</option>')
         .prop('disabled', true);

    $.getJSON(urlPhuongXa, { tinhThanh: tinh },
        function (ds) {
            var opts = '<option value="">-- Tất cả --</option>';
            if (ds && ds.length > 0) {
                $.each(ds, function (i, px) {
                    var sel = (px === phuongChon)
                        ? ' selected="selected"' : '';
                    opts += '<option value="' + px + '"'
                          + sel + '>' + px + '</option>';
                });
            }
            selPX.html(opts)
                 .prop('disabled', false)
                 .css({ background: '#fff', cursor: 'pointer' });
        }
    ).fail(function () {
        selPX.html('<option value="">-- Tất cả --</option>')
             .prop('disabled', false)
             .css({ background: '#fff', cursor: 'pointer' });
    });
}

// ✅ Chạy ngay khi DOM sẵn sàng
$(function () {
    // Lấy giá trị tỉnh/phường từ Razor (server-side)
    var tinhHienTai   = '@Html.Raw(ViewBag.TinhThanh ?? "")';
    var phuongHienTai = '@Html.Raw(ViewBag.PhuongXa ?? "")';

    // ✅ Set lại selected cho select tỉnh (phòng trường hợp bị reset)
    if (tinhHienTai) {
        $('#selTinhThanh').val(tinhHienTai);
        // Load phường/xã ngay lập tức
        loadPhuongXa(tinhHienTai, phuongHienTai);
    }
});

// Khi đổi tỉnh
$('#selTinhThanh').on('change', function () {
    loadPhuongXa($(this).val(), '');
});
    </script>
}